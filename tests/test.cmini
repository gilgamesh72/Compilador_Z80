byte key;
int pos;
int oldPos;
int delay;

pos = 22928; 

while (1 < 2) {
    poke(pos, 16);
    key = peek(23560);
    
    if (0 < key) {
        oldPos = pos;
        
        if (key == 97) { 
            pos = pos - 1;
        }
        if (key == 100) { 
            pos = pos + 1;
        }
        if (key == 119) { 
            pos = pos - 32;
        }
        if (key == 115) { 
            pos = pos + 32;
        }
        
        poke(oldPos, 56);
        poke(23560, 0);
        delay = 0;
        while (delay < 500) {
            delay = delay + 1;
        }
    }
}
