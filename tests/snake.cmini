// ============================================================
//  SNAKE - ZX Spectrum  (compilado con C-Mini -> Z80 ASM)
//
//  CONTROLES:
//    Joystick Kempston (puerto 31)  O  Teclado:
//    A = Izquierda   D = Derecha
//    W = Arriba      S = Abajo
//    ENTER = Reiniciar (luego de morir)
//
// ============================================================

int high_score;

int print_char(int ch, int row, int col) {
    int rom_addr;
    int scr_addr;
    int i;
    int data;
    
    rom_addr = 15360 + (ch * 8);
    // Calcular direccion de pantalla: 16384 + ((row & 24) * 256) + ((row & 7) * 32) + col
    scr_addr = 16384 + ((row & 24) * 256) + ((row & 7) * 32) + col;
    
    i = 0;
    while (i < 8) {
        data = peek(rom_addr + i);
        poke(scr_addr, data);
        scr_addr = scr_addr + 256;
        i = i + 1;
    }
    return 0;
}

int print_num(int num, int row, int col) {
    int d1;
    int d2;
    int d3;
    int temp;
    
    d1 = num / 100;
    temp = num % 100;
    d2 = temp / 10;
    d3 = temp % 10;
    
    print_char(48 + d1, row, col);
    print_char(48 + d2, row, col + 1);
    print_char(48 + d3, row, col + 2);
    return 0;
}

int print_texts() {
    // S C O R E :
    print_char(83, 22, 2);
    print_char(67, 22, 3);
    print_char(79, 22, 4);
    print_char(82, 22, 5);
    print_char(69, 22, 6);
    print_char(58, 22, 7);

    // H I G H :
    print_char(72, 22, 19);
    print_char(73, 22, 20);
    print_char(71, 22, 21);
    print_char(72, 22, 22);
    print_char(58, 22, 23);
    return 0;
}

// ===== BUFFER DE LA SERPIENTE =====
int snake[250];

// ===== ESTADO DEL JUEGO =====
int head_ptr;
int tail_ptr;
int dir;
int food_pos;
int score;
int game_running;
int app_running;
int rng;

int new_pos;
int snake_col;
int new_dir;
int cur_dir;
int delay_cnt;
int key_w;
int key_asd;
int key_enter;
int joy;
int fx;
int fy;
int cell_attr;
int i;
int j;
int tmp;
int ATT;

high_score = 0;
app_running = 1;

while (app_running == 1) {
    ATT = 22528;
    score = 0;
    game_running = 1;
    dir = 0;
    rng = 7919;

    // Borde cian
    out(0xFE, 5);

    // Limpiar pixeles
    i = 0;
    while (i < 6144) {
        poke(16384 + i, 0);
        i = i + 1;
    }

    // Limpiar atributos (pantalla negra, tinta blanca = 7)
    i = 0;
    while (i < 768) {
        poke(ATT + i, 7);
        i = i + 1;
    }

    // Dibujar textos y puntajes
    print_texts();
    print_num(score, 22, 9);
    print_num(high_score, 22, 25);

    // MARCO DEL CAMPO (cian brillante = 69)
    // Fila 0
    i = 0;
    while (i < 32) {
        poke(ATT + i, 69);
        i = i + 1;
    }
    // Fila 21 (21*32=672)
    i = 0;
    while (i < 32) {
        poke(ATT + 672 + i, 69);
        i = i + 1;
    }
    // Columnas 0 y 31
    i = 1;
    while (i <= 20) {
        tmp = i << 5;
        poke(ATT + tmp, 69);
        poke(ATT + tmp + 31, 69);
        i = i + 1;
    }

    // Serpiente Inicial (largo 3)
    snake[0] = 333;
    snake[1] = 334;
    snake[2] = 335;
    tail_ptr = 0;
    head_ptr = 2;

    poke(ATT + 333, 32);  // verde
    poke(ATT + 334, 32);
    poke(ATT + 335, 32);

    // Comida
    fx = 5;
    fy = 5;
    food_pos = 165;
    poke(ATT + food_pos, 16);  // rojo

    while (game_running == 1) {
        // VELOCIDAD
        delay_cnt = 2200;
        if (score > 5)  { delay_cnt = 1800; }
        if (score > 10) { delay_cnt = 1400; }
        if (score > 20) { delay_cnt = 1100; }
        if (score > 30) { delay_cnt = 850; }

        while (delay_cnt > 0) {
            delay_cnt = delay_cnt - 1;
        }

        joy = in(31);
        
        // W = puerto 0xFBFE (64510) bit 1 (valor 2)
        key_w = in(64510);
        // ASD = puerto 0xFDFE (65022): A=bit 0, S=bit 1, D=bit 2
        key_asd = in(65022);

        new_dir = dir;

        if ((joy & 8) != 0) { new_dir = 2; } // arr
        if ((joy & 4) != 0) { new_dir = 3; } // abj
        if ((joy & 2) != 0) { new_dir = 1; } // izq
        if ((joy & 1) != 0) { new_dir = 0; } // der

        if ((key_w & 2) == 0) { new_dir = 2; }   // W -> arriba
        if ((key_asd & 2) == 0) { new_dir = 3; } // S -> abajo
        if ((key_asd & 1) == 0) { new_dir = 1; } // A -> izq
        if ((key_asd & 4) == 0) { new_dir = 0; } // D -> der

        cur_dir = dir;
        if (new_dir == 0) { if (cur_dir != 1) { dir = 0; } }
        if (new_dir == 1) { if (cur_dir != 0) { dir = 1; } }
        if (new_dir == 2) { if (cur_dir != 3) { dir = 2; } }
        if (new_dir == 3) { if (cur_dir != 2) { dir = 3; } }

        new_pos = snake[head_ptr];
        if (dir == 0) { new_pos = new_pos + 1; }
        if (dir == 1) { new_pos = new_pos - 1; }
        if (dir == 2) { new_pos = new_pos - 32; }
        if (dir == 3) { new_pos = new_pos + 32; }

        snake_col = new_pos & 31;
        if (snake_col == 0)   { game_running = 0; }
        if (snake_col == 31)  { game_running = 0; }
        if (new_pos < 32)   { game_running = 0; }
        if (new_pos >= 672) { game_running = 0; }

        if (game_running == 1) {
            cell_attr = peek(ATT + new_pos);
            if (cell_attr == 32) { game_running = 0; }
        }

        if (game_running == 1) {
            head_ptr = head_ptr + 1;
            if (head_ptr >= 250) { head_ptr = 0; }
            snake[head_ptr] = new_pos;

            poke(ATT + new_pos, 32);

            if (new_pos == food_pos) {
                score = score + 1;
                print_num(score, 22, 9);
                if (score > high_score) {
                    high_score = score;
                    print_num(high_score, 22, 25);
                }

                rng = rng ^ (rng << 7);
                rng = rng & 32767;
                rng = rng ^ (rng >> 9);
                rng = rng & 32767;
                rng = rng ^ (rng << 8);
                rng = rng & 32767;

                fx = (rng & 15) + 8;
                tmp = rng >> 5;
                fy = (tmp & 7) + 3;
                food_pos = (fy << 5) + fx;

                cell_attr = peek(ATT + food_pos);
                while (cell_attr != 7) {
                    fx = fx + 1;
                    if (fx >= 30) {
                        fx = 2;
                        fy = fy + 1;
                        if (fy >= 20) { fy = 2; }
                    }
                    food_pos = (fy << 5) + fx;
                    cell_attr = peek(ATT + food_pos);
                }

                poke(ATT + food_pos, 16);
            } else {
                poke(ATT + snake[tail_ptr], 7);
                tail_ptr = tail_ptr + 1;
                if (tail_ptr >= 250) { tail_ptr = 0; }
            }
        }
    }

    // GAME OVER
    out(0xFE, 2);

    i = 1;
    while (i <= 20) {
        tmp = i << 5;
        j = 1;
        while (j <= 30) {
            poke(ATT + tmp + j, 16);
            j = j + 1;
        }
        i = i + 1;
    }

    // G A M E O V E R
    print_char(71, 10, 11);
    print_char(65, 10, 12);
    print_char(77, 10, 13);
    print_char(69, 10, 14);
    print_char(32, 10, 15);
    print_char(79, 10, 16);
    print_char(86, 10, 17);
    print_char(69, 10, 18);
    print_char(82, 10, 19);

    // Wait for ENTER (puerto 49150 = 0xBFFE, bit 0 = valor 1)
    key_enter = 1;
    while (key_enter != 0) {
        key_enter = in(49150) & 1;
    }
    // debouncing
    delay_cnt = 10000;
    while (delay_cnt > 0) { delay_cnt = delay_cnt - 1; }
}
return 0;
